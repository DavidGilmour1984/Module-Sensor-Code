<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>ESP32 VP Monitor</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:Helvetica,Arial,sans-serif;background:#f5f7fb;color:#1e293b;font-size:14px}
.shell{max-width:960px;margin:0 auto;padding:1.5rem;display:flex;flex-direction:column;gap:1rem}
.topbar{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.brand{font-size:16px;font-weight:700}
.brand span{font-weight:400;font-size:13px;color:#64748b;margin-left:8px}
.pills{display:flex;gap:8px;align-items:center}
.pill{font-size:12px;padding:4px 12px;border-radius:20px;border:1px solid #cbd5e1;color:#64748b;background:#fff}
.pill.ok{background:#dcfce7;color:#166534;border-color:#86efac}
.pill.err{background:#fee2e2;color:#991b1b;border-color:#fca5a5}
.pill.rec{background:#fef3c7;color:#92400e;border-color:#fcd34d;display:none}
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px}
.metric{background:#fff;border-radius:8px;padding:1rem;text-align:center;border:1px solid #e2e8f0}
.metric .lbl{font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px}
.metric .val{font-size:22px;font-weight:700;color:#2563eb}
.metric .unit{font-size:12px;color:#94a3b8;margin-left:2px;font-weight:400}
.card{background:#fff;border-radius:10px;padding:1.25rem;border:1px solid #e2e8f0}
.card-head{font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px}
.chart-wrap{position:relative;width:100%;height:280px}
.controls{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.ctrl label{font-size:12px;color:#64748b;display:block;margin-bottom:4px}
.ctrl input[type=range]{width:100%;accent-color:#2563eb}
.ctrl .readout{font-size:13px;font-weight:600;color:#1e293b;margin-top:3px}
.btn-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
button{font-family:Helvetica,Arial,sans-serif;font-size:13px;padding:8px 16px;border-radius:7px;border:1px solid #cbd5e1;background:#fff;color:#1e293b;cursor:pointer;font-weight:600;transition:background .12s}
button:hover:not(:disabled){background:#f1f5f9}
button:disabled{opacity:.4;cursor:default}
button.primary{background:#2563eb;color:#fff;border-color:#2563eb}
button.primary:hover:not(:disabled){background:#1e40af;border-color:#1e40af}
button.danger{background:#fee2e2;color:#991b1b;border-color:#fca5a5}
button.danger:hover:not(:disabled){background:#fecaca}
.log{max-height:130px;overflow-y:auto;background:#f8fafc;border-radius:6px;padding:8px 10px;font-family:monospace;font-size:11px;color:#64748b;border:1px solid #e2e8f0}
.log p{margin:1px 0}
</style>
</head>
<body>
<div class="shell">

  <div class="topbar">
    <div class="brand">ESP32 VP Monitor <span>GPIO 36 · ADC1_CH0</span></div>
    <div class="pills">
      <span class="pill" id="blePill">Not connected</span>
      <span class="pill rec" id="recPill">● Recording</span>
    </div>
  </div>

  <div class="metrics">
    <div class="metric"><div class="lbl">Voltage</div><div class="val" id="mVolt">—<span class="unit">V</span></div></div>
    <div class="metric"><div class="lbl">Raw ADC</div><div class="val" id="mRaw">—</div></div>
    <div class="metric"><div class="lbl">Min</div><div class="val" id="mMin">—<span class="unit">V</span></div></div>
    <div class="metric"><div class="lbl">Max</div><div class="val" id="mMax">—<span class="unit">V</span></div></div>
    <div class="metric"><div class="lbl">Samples</div><div class="val" id="mCount">0</div></div>
  </div>

  <div class="card">
    <div class="card-head">Live plot</div>
    <div class="chart-wrap">
      <canvas id="chart" role="img" aria-label="Live voltage plot from ESP32 VP pin">No data yet.</canvas>
    </div>
  </div>

  <div class="card">
    <div class="card-head">Settings</div>
    <div class="controls">
      <div class="ctrl">
        <label>Sample rate (sent to ESP32)</label>
        <input type="range" id="rateSlider" min="50" max="5000" step="50" value="500">
        <div class="readout" id="rateOut">500 ms</div>
      </div>
      <div class="ctrl">
        <label>Plot window</label>
        <input type="range" id="windowSlider" min="20" max="500" step="10" value="100">
        <div class="readout" id="windowOut">100 points</div>
      </div>
      <div class="ctrl">
        <label>Y-axis min (V)</label>
        <input type="range" id="yMinSlider" min="0" max="3.0" step="0.1" value="0">
        <div class="readout" id="yMinOut">0.0 V</div>
      </div>
      <div class="ctrl">
        <label>Y-axis max (V)</label>
        <input type="range" id="yMaxSlider" min="0.1" max="3.3" step="0.1" value="3.3">
        <div class="readout" id="yMaxOut">3.3 V</div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-head">Connection & data</div>
    <div class="btn-row">
      <button class="primary" id="btnConnect">Connect</button>
      <button id="btnDisconnect" disabled>Disconnect</button>
      <button id="btnClear">Clear data</button>
      <button id="btnCSV" disabled>Download CSV</button>
    </div>
    <div class="card-head">Log</div>
    <div class="log" id="log"><p>Waiting for connection…</p></div>
  </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
const SVC_UUID  = "12345678-1234-1234-1234-123456789abc";
const DATA_UUID = "abcd1234-ab12-ab12-ab12-abcdef123456";
const CFG_UUID  = "abcd5678-ab12-ab12-ab12-abcdef123456";

let bleDevice=null, dataChar=null, cfgChar=null;
let recorded=[];
let plotWindow=100;
let yMin=0, yMax=3.3;

const $=id=>document.getElementById(id);

function log(msg){
  const p=document.createElement('p');
  p.textContent='['+new Date().toLocaleTimeString()+'] '+msg;
  $('log').appendChild(p);
  $('log').scrollTop=$('log').scrollHeight;
}

const ctx=document.getElementById('chart').getContext('2d');
const chart=new Chart(ctx,{
  type:'line',
  data:{
    labels:[],
    datasets:[{
      label:'Voltage (V)',
      data:[],
      borderColor:'#2563eb',
      borderWidth:1.5,
      pointRadius:0,
      tension:0.3,
      fill:true,
      backgroundColor:'rgba(37,99,235,0.07)'
    }]
  },
  options:{
    responsive:true,
    maintainAspectRatio:false,
    animation:{duration:0},
    plugins:{legend:{display:false}},
    scales:{
      x:{ticks:{maxTicksLimit:8,color:'#94a3b8',font:{size:11}},grid:{color:'rgba(0,0,0,0.04)'}},
      y:{min:0,max:3.3,ticks:{color:'#94a3b8',font:{size:11},callback:v=>v.toFixed(1)+'V'},grid:{color:'rgba(0,0,0,0.04)'}}
    }
  }
});

function updateMetrics(){
  if(!recorded.length) return;
  const volts=recorded.map(r=>r.v);
  const last=recorded[recorded.length-1];
  $('mVolt').innerHTML=last.v.toFixed(4)+'<span class="unit">V</span>';
  $('mRaw').textContent=last.raw;
  $('mMin').innerHTML=Math.min(...volts).toFixed(4)+'<span class="unit">V</span>';
  $('mMax').innerHTML=Math.max(...volts).toFixed(4)+'<span class="unit">V</span>';
  $('mCount').textContent=recorded.length;
}

function pushToChart(tsLabel,v){
  const d=chart.data;
  d.labels.push(tsLabel);
  d.datasets[0].data.push(v);
  if(d.labels.length>plotWindow){d.labels.shift();d.datasets[0].data.shift();}
  chart.options.scales.y.min=yMin;
  chart.options.scales.y.max=yMax;
  chart.update('none');
}

function onData(e){
  const txt=new TextDecoder().decode(e.target.value);
  const parts=txt.split(',');
  if(parts.length<3) return;
  const ts=parseInt(parts[0]);
  const v=parseFloat(parts[1]);
  const raw=parseInt(parts[2]);
  recorded.push({ts,v,raw,wall:new Date().toISOString()});
  pushToChart((ts/1000).toFixed(2)+'s',v);
  updateMetrics();
}

async function sendRate(ms){
  if(!cfgChar) return;
  await cfgChar.writeValue(new TextEncoder().encode('RATE:'+ms));
  log('Sample rate updated: '+ms+' ms');
}

$('btnConnect').addEventListener('click',async()=>{
  if(!navigator.bluetooth){
    alert('Web Bluetooth not supported.\nUse Chrome or Edge on Android or desktop Windows/macOS.');
    return;
  }
  try{
    log('Scanning for ESP32_VP_Sensor…');
    bleDevice=await navigator.bluetooth.requestDevice({
      filters:[{name:'ESP32_VP_Sensor'}],
      optionalServices:[SVC_UUID]
    });
    bleDevice.addEventListener('gattserverdisconnected',()=>{
      log('Device disconnected.');
      $('blePill').textContent='Disconnected';
      $('blePill').className='pill err';
      $('recPill').style.display='none';
      $('btnConnect').disabled=false;
      $('btnDisconnect').disabled=true;
    });
    const server=await bleDevice.gatt.connect();
    const svc=await server.getPrimaryService(SVC_UUID);
    dataChar=await svc.getCharacteristic(DATA_UUID);
    cfgChar=await svc.getCharacteristic(CFG_UUID);
    await dataChar.startNotifications();
    dataChar.addEventListener('characteristicvaluechanged',onData);
    $('blePill').textContent='Connected — '+bleDevice.name;
    $('blePill').className='pill ok';
    $('recPill').style.display='';
    $('btnConnect').disabled=true;
    $('btnDisconnect').disabled=false;
    $('btnCSV').disabled=false;
    log('Connected to '+bleDevice.name);
    await sendRate(parseInt($('rateSlider').value));
  }catch(err){
    log('Error: '+err.message);
    $('blePill').textContent='Failed';
    $('blePill').className='pill err';
  }
});

$('btnDisconnect').addEventListener('click',()=>{
  if(bleDevice&&bleDevice.gatt.connected) bleDevice.gatt.disconnect();
  $('recPill').style.display='none';
  $('btnDisconnect').disabled=true;
  $('btnConnect').disabled=false;
});

$('btnClear').addEventListener('click',()=>{
  recorded=[];
  chart.data.labels=[];
  chart.data.datasets[0].data=[];
  chart.update('none');
  ['mVolt','mRaw','mMin','mMax'].forEach(id=>{$(id).innerHTML='—';});
  $('mCount').textContent='0';
  log('Data cleared.');
});

$('btnCSV').addEventListener('click',()=>{
  if(!recorded.length){log('No data to export.');return;}
  const rows=['timestamp_ms,voltage_V,raw_ADC,wall_time',
    ...recorded.map(r=>`${r.ts},${r.v.toFixed(4)},${r.raw},${r.wall}`)];
  const blob=new Blob([rows.join('\n')],{type:'text/csv'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='vp_log_'+new Date().toISOString().replace(/[:.]/g,'-')+'.csv';
  a.click();
  log('CSV exported — '+recorded.length+' rows.');
});

$('rateSlider').addEventListener('input',function(){$('rateOut').textContent=this.value+' ms';});
$('rateSlider').addEventListener('change',function(){sendRate(parseInt(this.value));});
$('windowSlider').addEventListener('input',function(){plotWindow=parseInt(this.value);$('windowOut').textContent=plotWindow+' points';});
$('yMinSlider').addEventListener('input',function(){
  yMin=parseFloat(this.value);$('yMinOut').textContent=yMin.toFixed(1)+' V';
  chart.options.scales.y.min=yMin;chart.update('none');
});
$('yMaxSlider').addEventListener('input',function(){
  yMax=parseFloat(this.value);$('yMaxOut').textContent=yMax.toFixed(1)+' V';
  chart.options.scales.y.max=yMax;chart.update('none');
});
</script>
</body>
</html>
