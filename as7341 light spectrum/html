<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AS7341 Spectral Analyser</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;700;800&display=swap');

:root {
  --bg:      #080b0f;
  --surface: #0e1218;
  --panel:   #121820;
  --border:  #1c2333;
  --text:    #b8c8d8;
  --dim:     #3a4a5a;
  --accent:  #00d4aa;
  --ok:      #00e676;
  --warn:    #ffab40;
  --err:     #ff4560;
  --match:   #00e676;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Mono', monospace;
  font-weight: 300;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── Header ── */
header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
  gap: 10px;
}
header h1 {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--accent);
}
header h1 span { color: var(--dim); font-weight: 400; }

.controls { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

select {
  font-family: 'DM Mono', monospace;
  font-size: .75rem;
  background: var(--panel);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 6px 10px;
  border-radius: 4px;
}

btn, button {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .7rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text);
  padding: 6px 14px;
  border-radius: 4px;
  cursor: pointer;
  transition: all .15s;
  white-space: nowrap;
}
button:hover { border-color: var(--accent); color: var(--accent); }
button:disabled { opacity: .3; cursor: not-allowed; }
button.primary { border-color: var(--accent); color: var(--accent); }
button.primary:hover { background: var(--accent); color: var(--bg); }
button.danger { border-color: var(--err); color: var(--err); }
button.danger:hover { background: var(--err); color: #fff; }
button.save-btn { border-color: var(--warn); color: var(--warn); }
button.save-btn:hover { background: var(--warn); color: var(--bg); }

.status-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--dim); flex-shrink: 0;
  transition: background .3s, box-shadow .3s;
}
.status-dot.connected { background: var(--ok); box-shadow: 0 0 6px var(--ok); }
.status-dot.receiving { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
.status-dot.error     { background: var(--err);  box-shadow: 0 0 6px var(--err); }
#statusText { font-size: .72rem; }

/* ── Main layout ── */
main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 16px 20px;
}

/* ── Graph panel ── */
.graph-panel {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 18px 20px 14px;
  position: relative;
}
.panel-label {
  font-family: 'Syne', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--dim);
  margin-bottom: 12px;
}
canvas#specChart { width: 100%; display: block; }

/* ── Bottom row: cal + match side by side ── */
.bottom-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
@media (max-width: 640px) { .bottom-row { grid-template-columns: 1fr; } }

/* ── Cal panel ── */
.cal-panel, .match-panel {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cal-actions { display: flex; gap: 8px; flex-wrap: wrap; }

.cal-bars {
  display: flex;
  align-items: flex-end;
  gap: 3px;
  height: 40px;
}
.cal-bar-wrap { display: flex; flex-direction: column; align-items: center; gap: 2px; flex: 1; }
.cal-bar {
  width: 100%; border-radius: 2px 2px 0 0;
  transition: height .3s ease;
  min-height: 2px;
}
.cal-bar-label { font-size: .5rem; color: var(--dim); }
#calStatus {
  font-size: .7rem;
  color: var(--dim);
  font-style: italic;
}
#calStatus.active { color: var(--ok); font-style: normal; }

/* ── Match panel ── */
.saved-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
  max-height: 160px;
  overflow-y: auto;
}
.saved-entry {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 5px;
  font-size: .72rem;
  transition: border-color .2s;
  cursor: default;
}
.saved-entry.matched {
  border-color: var(--match);
  background: rgba(0,230,118,.06);
}
.saved-swatch {
  width: 18px; height: 18px; border-radius: 3px; flex-shrink: 0;
  border: 1px solid rgba(255,255,255,.1);
}
.saved-name { flex: 1; color: var(--text); }
.match-score {
  font-size: .65rem;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  color: var(--dim);
  min-width: 36px;
  text-align: right;
}
.match-score.hit { color: var(--match); }
.del-btn {
  font-size: .6rem;
  padding: 2px 6px;
  border-radius: 3px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--dim);
  cursor: pointer;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  letter-spacing: .05em;
}
.del-btn:hover { border-color: var(--err); color: var(--err); }

.match-banner {
  display: none;
  padding: 8px 14px;
  background: rgba(0,230,118,.1);
  border: 1px solid var(--match);
  border-radius: 5px;
  color: var(--match);
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .85rem;
  letter-spacing: .08em;
  text-align: center;
  animation: pulse 1s ease infinite alternate;
}
.match-banner.visible { display: block; }
@keyframes pulse { from { opacity: .7; } to { opacity: 1; } }

/* ── Threshold ── */
.threshold-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.threshold-row label {
  font-family: 'Syne', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--dim);
  white-space: nowrap;
}
input[type=range] {
  flex: 1;
  min-width: 80px;
  accent-color: var(--accent);
  height: 4px;
}
#threshVal {
  font-size: .8rem;
  color: var(--accent);
  min-width: 32px;
  text-align: right;
}

/* ── Save name input ── */
.save-row { display: flex; gap: 8px; }
.save-row input[type=text] {
  flex: 1;
  font-family: 'DM Mono', monospace;
  font-size: .75rem;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 6px 10px;
  border-radius: 4px;
  outline: none;
}
.save-row input[type=text]:focus { border-color: var(--warn); }

.io-row { display: flex; gap: 8px; }

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
</style>
</head>
<body>

<header>
  <h1>AS7341 <span>/ Spectral Analyser</span></h1>
  <div class="controls">
    <select id="baudSelect">
      <option value="9600">9600</option>
      <option value="115200" selected>115200</option>
    </select>
    <div style="display:flex;align-items:center;gap:7px">
      <div class="status-dot" id="statusDot"></div>
      <span id="statusText">Not connected</span>
    </div>
    <button class="primary" id="btnConnect">Connect</button>
    <button class="danger" id="btnDisconnect" disabled>Disconnect</button>
  </div>
</header>

<main>

  <!-- Spectral graph -->
  <div class="graph-panel">
    <div class="panel-label">Live Spectral Profile — wavelength (nm) vs intensity</div>
    <canvas id="specChart" height="280"></canvas>
  </div>

  <div class="bottom-row">

    <!-- Dark calibration -->
    <div class="cal-panel">
      <div class="panel-label">Dark Calibration</div>
      <div class="cal-actions">
        <button id="btnDarkCal">Capture Dark</button>
        <button class="danger" id="btnResetCal">Reset Cal</button>
      </div>
      <div class="cal-bars" id="calBars"></div>
      <div id="calStatus">No calibration captured</div>
    </div>

    <!-- Profile save & match -->
    <div class="match-panel">
      <div class="panel-label">Profile Match</div>

      <div class="threshold-row">
        <label>Tolerance</label>
        <input type="range" id="threshSlider" min="50" max="100" value="85" step="1">
        <span id="threshVal">85</span>
      </div>

      <div class="match-banner" id="matchBanner">MATCH DETECTED</div>

      <div class="save-row">
        <input type="text" id="saveName" placeholder="Profile name…" maxlength="24">
        <button class="save-btn" id="btnSave">Save</button>
      </div>

      <div class="io-row">
        <button id="btnExport">Export JSON</button>
        <button id="btnImport">Load JSON</button>
        <input type="file" id="fileInput" accept=".json" style="display:none">
      </div>

      <div class="saved-list" id="savedList">
        <div style="font-size:.7rem;color:var(--dim);font-style:italic">No profiles saved yet</div>
      </div>
    </div>

  </div>
</main>

<script>
// ── Channel definitions ─────────────────────────────────────────────────
// Wavelengths are centre nm of each AS7341 channel
const CH = [
  { nm: 415, label:'F1\n415',  color:'#9c27b0' },
  { nm: 445, label:'F2\n445',  color:'#3f51b5' },
  { nm: 480, label:'F3\n480',  color:'#2196f3' },
  { nm: 515, label:'F4\n515',  color:'#00bcd4' },
  { nm: 555, label:'F5\n555',  color:'#4caf50' },
  { nm: 590, label:'F6\n590',  color:'#cddc39' },
  { nm: 630, label:'F7\n630',  color:'#ff9800' },
  { nm: 680, label:'F8\n680',  color:'#f44336' },
  { nm: null, label:'CLR',     color:'#78909c' },
  { nm: null, label:'NIR',     color:'#37474f' },
];

// Spectral channels only (indices 0–7) for profile matching
const SPEC_IDX = [0,1,2,3,4,5,6,7];

// CIE XYZ weights for colour swatch
const XYZ_W = [
  [0.0173,0.0005,0.0897],[0.3362,0.0380,1.7721],[0.0956,0.1390,0.8120],
  [0.0147,0.3230,0.0549],[0.1954,0.9950,0.0040],[1.0544,0.7570,0.0000],
  [0.2650,0.1070,0.0000],[0.0170,0.0061,0.0000],
];

// ── State ───────────────────────────────────────────────────────────────
let port=null, reader=null, readLoopActive=false;
let darkOffset = new Array(10).fill(0);
let darkCaptured = false;
let lastRaw = new Array(10).fill(0);
let lastCorrected = new Array(10).fill(0);
let savedProfiles = [];   // [{name, vals(8), color}]
let threshold = 85;

// ── DOM ─────────────────────────────────────────────────────────────────
const canvas      = document.getElementById('specChart');
const ctx         = canvas.getContext('2d');
const btnConnect  = document.getElementById('btnConnect');
const btnDisc     = document.getElementById('btnDisconnect');
const btnDarkCal  = document.getElementById('btnDarkCal');
const btnResetCal = document.getElementById('btnResetCal');
const btnSave     = document.getElementById('btnSave');
const calBarsEl   = document.getElementById('calBars');
const calStatus   = document.getElementById('calStatus');
const savedList   = document.getElementById('savedList');
const matchBanner = document.getElementById('matchBanner');
const threshSlider= document.getElementById('threshSlider');
const threshVal   = document.getElementById('threshVal');
const saveNameEl  = document.getElementById('saveName');

// ── Build dark cal mini-bars ─────────────────────────────────────────────
CH.forEach((ch, i) => {
  const wrap = document.createElement('div');
  wrap.className = 'cal-bar-wrap';
  wrap.innerHTML = `<div class="cal-bar" id="cb${i}" style="height:2px;background:${ch.color}"></div>
                    <div class="cal-bar-label">${ch.label.split('\n')[0]}</div>`;
  calBarsEl.appendChild(wrap);
});

// ── Threshold slider ─────────────────────────────────────────────────────
threshSlider.addEventListener('input', () => {
  threshold = +threshSlider.value;
  threshVal.textContent = threshold;
  checkMatches(lastCorrected);
});

// ── Serial connect ───────────────────────────────────────────────────────
btnConnect.addEventListener('click', async () => {
  if (!('serial' in navigator)) { setStatus('error','Web Serial not supported — use Chrome/Edge'); return; }
  try {
    port = await navigator.serial.requestPort();
    await port.open({ baudRate: +document.getElementById('baudSelect').value });
    setStatus('connected','Connected');
    btnConnect.disabled = true; btnDisc.disabled = false;
    startReadLoop();
  } catch(e) { setStatus('error','Failed: '+e.message); }
});

btnDisc.addEventListener('click', async () => {
  readLoopActive = false;
  try { if(reader){ await reader.cancel(); reader=null; } } catch{}
  try { await port.close(); } catch{}
  port=null;
  setStatus('','Disconnected');
  btnConnect.disabled=false; btnDisc.disabled=true;
});

// ── Dark calibration ─────────────────────────────────────────────────────
btnDarkCal.addEventListener('click', () => {
  darkOffset = [...lastRaw];
  darkCaptured = true;
  calStatus.textContent = 'Dark captured — offsets: ' + darkOffset.slice(0,8).map(v=>v.toLocaleString()).join(', ');
  calStatus.className = 'active';
  // Show mini bars scaled to dark offset values
  const mx = Math.max(...darkOffset, 1);
  darkOffset.forEach((v,i) => {
    const bar = document.getElementById('cb'+i);
    if(bar) bar.style.height = Math.max(2, Math.round(v/mx*36)) + 'px';
  });
});

btnResetCal.addEventListener('click', () => {
  darkOffset = new Array(10).fill(0);
  darkCaptured = false;
  calStatus.textContent = 'No calibration captured';
  calStatus.className = '';
  CH.forEach((_,i) => { const b=document.getElementById('cb'+i); if(b) b.style.height='2px'; });
});

// ── Save profile ─────────────────────────────────────────────────────────
btnSave.addEventListener('click', () => {
  const name = saveNameEl.value.trim() || ('Profile ' + (savedProfiles.length+1));
  const vals = SPEC_IDX.map(i => lastCorrected[i]);
  const color = spectralToHex(lastCorrected);
  savedProfiles.push({ name, vals, color });
  saveNameEl.value = '';
  renderSavedList();
  checkMatches(lastCorrected);
});

// ── Read loop ────────────────────────────────────────────────────────────
async function startReadLoop() {
  readLoopActive = true;
  const decoder = new TextDecoderStream();
  port.readable.pipeTo(decoder.writable);
  reader = decoder.readable.getReader();
  let buf = '';
  try {
    while (readLoopActive) {
      const { value, done } = await reader.read();
      if (done) break;
      buf += value;
      let nl;
      while ((nl = buf.indexOf('\n')) !== -1) {
        const line = buf.slice(0, nl).trim();
        buf = buf.slice(nl+1);
        if (line) parseLine(line);
      }
    }
  } catch(e) { if(readLoopActive) setStatus('error','Read error: '+e.message); }
}

function parseLine(line) {
  if (!/^[\d,]+$/.test(line)) return;
  const parts = line.split(',').map(Number);
  if (parts.length !== 10 || parts.some(isNaN)) return;
  setStatus('receiving','Receiving');
  lastRaw = [...parts];
  lastCorrected = parts.map((v,i) => Math.max(0, v - darkOffset[i]));
  drawSpectrum(lastCorrected);
  checkMatches(lastCorrected);
}

// ── Spectral graph ───────────────────────────────────────────────────────
function drawSpectrum(vals) {
  const DPR = window.devicePixelRatio || 1;
  const W = canvas.parentElement.clientWidth - 40;
  const H = 280;
  canvas.width  = W * DPR;
  canvas.height = H * DPR;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(DPR, DPR);

  const PAD = { top:16, right:20, bottom:52, left:58 };
  const gw = W - PAD.left - PAD.right;
  const gh = H - PAD.top  - PAD.bottom;

  ctx.clearRect(0, 0, W, H);

  // Grid
  const gridLines = 5;
  const maxVal = Math.max(...vals, 1);

  ctx.strokeStyle = 'rgba(28,35,51,.95)';
  ctx.lineWidth = 1;
  for (let i=0; i<=gridLines; i++) {
    const y = PAD.top + gh * (i/gridLines);
    ctx.beginPath(); ctx.moveTo(PAD.left, y); ctx.lineTo(PAD.left+gw, y); ctx.stroke();
  }

  // Y axis labels
  ctx.fillStyle = 'rgba(58,74,90,.9)';
  ctx.font = `10px 'DM Mono'`;
  ctx.textAlign = 'right';
  for (let i=0; i<=gridLines; i++) {
    const val = Math.round(maxVal * (1 - i/gridLines));
    const y   = PAD.top + gh * (i/gridLines);
    ctx.fillText(val.toLocaleString(), PAD.left-8, y+3);
  }

  // Y axis title
  ctx.save();
  ctx.translate(13, PAD.top + gh/2);
  ctx.rotate(-Math.PI/2);
  ctx.fillStyle = 'rgba(58,74,90,.7)';
  ctx.font = `10px 'DM Mono'`;
  ctx.textAlign = 'center';
  ctx.fillText('Intensity (counts)', 0, 0);
  ctx.restore();

  // X axis — only spectral channels, spaced by nm
  // Map wavelength 415–680 nm to x axis
  const NM_MIN = 400;
  const NM_MAX = 700;
  const nmToX = nm => PAD.left + (nm - NM_MIN) / (NM_MAX - NM_MIN) * gw;

  // X axis nm labels
  ctx.fillStyle = 'rgba(58,74,90,.8)';
  ctx.font = `10px 'DM Mono'`;
  ctx.textAlign = 'center';
  for (let nm=400; nm<=700; nm+=50) {
    const x = nmToX(nm);
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(28,35,51,.6)';
    ctx.lineWidth = 1;
    ctx.moveTo(x, PAD.top); ctx.lineTo(x, PAD.top+gh);
    ctx.stroke();
    ctx.fillStyle = 'rgba(58,74,90,.8)';
    ctx.fillText(nm+'nm', x, PAD.top+gh+16);
  }

  // X axis title
  ctx.fillStyle = 'rgba(58,74,90,.7)';
  ctx.font = `10px 'DM Mono'`;
  ctx.textAlign = 'center';
  ctx.fillText('Wavelength (nm)', PAD.left + gw/2, H-6);

  // Saved profile ghost lines (draw under current)
  savedProfiles.forEach(prof => {
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(255,255,255,.08)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4,4]);
    prof.vals.forEach((v, ii) => {
      const ch = CH[ii];
      if (!ch.nm) return;
      const x = nmToX(ch.nm);
      const y = PAD.top + gh * (1 - v/maxVal);
      ii===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    });
    ctx.stroke();
    ctx.setLineDash([]);
  });

  // ── Draw spectral bars + connecting curve ─────────────────────────────
  // Compute bar positions
  const specChs = CH.filter(c=>c.nm!==null);
  const barW = Math.max(12, gw / (NM_MAX-NM_MIN) * 22); // ~22nm wide bars

  // Gradient bars
  specChs.forEach((ch, ii) => {
    const v = vals[ii];
    const x = nmToX(ch.nm);
    const barH = gh * (v / maxVal);
    const y = PAD.top + gh - barH;

    // Glow under bar
    const grd = ctx.createLinearGradient(0, y, 0, PAD.top+gh);
    grd.addColorStop(0, ch.color + 'cc');
    grd.addColorStop(1, ch.color + '11');
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.roundRect(x - barW/2, y, barW, barH, [3,3,0,0]);
    ctx.fill();

    // Bar outline
    ctx.strokeStyle = ch.color;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Top glow dot
    ctx.beginPath();
    ctx.arc(x, y, 4, 0, Math.PI*2);
    ctx.fillStyle = ch.color;
    ctx.shadowColor = ch.color;
    ctx.shadowBlur = 10;
    ctx.fill();
    ctx.shadowBlur = 0;

    // Channel label below x axis
    ctx.fillStyle = ch.color;
    ctx.font = `9px 'DM Mono'`;
    ctx.textAlign = 'center';
    ctx.fillText(ch.label.split('\n')[0], x, PAD.top+gh+28);
    ctx.fillStyle = 'rgba(58,74,90,.6)';
    ctx.fillText(ch.label.split('\n')[1]||'', x, PAD.top+gh+39);
  });

  // Connecting line through bar tops
  ctx.beginPath();
  ctx.strokeStyle = 'rgba(255,255,255,.18)';
  ctx.lineWidth = 1.5;
  ctx.lineJoin = 'round';
  specChs.forEach((ch, ii) => {
    const x = nmToX(ch.nm);
    const y = PAD.top + gh * (1 - vals[ii]/maxVal);
    ii===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
  });
  ctx.stroke();

  // Clear + NIR as small sidebar indicators (right of main plot)
  // (omitted from main nm axis since they don't have a simple wavelength)
}

// ── Profile matching ─────────────────────────────────────────────────────
function cosineSimilarity(a, b) {
  // Normalised dot product — 100 = identical profile shape
  let dot=0, magA=0, magB=0;
  for (let i=0; i<a.length; i++) { dot+=a[i]*b[i]; magA+=a[i]*a[i]; magB+=b[i]*b[i]; }
  if (magA===0||magB===0) return 0;
  return Math.round((dot / (Math.sqrt(magA)*Math.sqrt(magB)))*100);
}

function checkMatches(corrected) {
  if (savedProfiles.length===0) return;
  const current = SPEC_IDX.map(i=>corrected[i]);
  let anyMatch = false;
  let bestName = '';
  let bestScore = 0;

  savedProfiles.forEach((prof, idx) => {
    const score = cosineSimilarity(current, prof.vals);
    const el = document.getElementById('se'+idx);
    const sc = document.getElementById('ss'+idx);
    if (el && sc) {
      sc.textContent = score;
      if (score >= threshold) {
        el.classList.add('matched');
        sc.classList.add('hit');
        anyMatch = true;
        if (score > bestScore) { bestScore=score; bestName=prof.name; }
      } else {
        el.classList.remove('matched');
        sc.classList.remove('hit');
      }
    }
  });

  if (anyMatch) {
    matchBanner.textContent = `MATCH — ${bestName} (${bestScore}%)`;
    matchBanner.classList.add('visible');
  } else {
    matchBanner.classList.remove('visible');
  }
}

// ── Render saved list ────────────────────────────────────────────────────
function renderSavedList() {
  if (savedProfiles.length===0) {
    savedList.innerHTML = '<div style="font-size:.7rem;color:var(--dim);font-style:italic">No profiles saved yet</div>';
    return;
  }
  savedList.innerHTML = '';
  savedProfiles.forEach((prof, idx) => {
    const el = document.createElement('div');
    el.className = 'saved-entry';
    el.id = 'se'+idx;
    el.innerHTML = `
      <div class="saved-swatch" style="background:${prof.color}"></div>
      <div class="saved-name">${prof.name}</div>
      <div class="match-score" id="ss${idx}">—</div>
      <button class="del-btn" onclick="deleteProfile(${idx})">DEL</button>`;
    savedList.appendChild(el);
  });
}

function deleteProfile(idx) {
  savedProfiles.splice(idx,1);
  renderSavedList();
  checkMatches(lastCorrected);
}

// ── Export / Import profiles ─────────────────────────────────────────────
document.getElementById('btnExport').addEventListener('click', () => {
  if (savedProfiles.length === 0) { alert('No profiles to export.'); return; }
  const payload = {
    version: 1,
    exported: new Date().toISOString(),
    darkOffset,
    darkCaptured,
    profiles: savedProfiles
  };
  const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'as7341_profiles_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
});

document.getElementById('btnImport').addEventListener('click', () => {
  document.getElementById('fileInput').click();
});

document.getElementById('fileInput').addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    try {
      const payload = JSON.parse(ev.target.result);
      if (!payload.profiles || !Array.isArray(payload.profiles)) throw new Error('Invalid file format');

      // Offer to merge or replace
      const action = savedProfiles.length > 0
        ? confirm('Add to existing profiles?\n\nOK = merge   Cancel = replace')
        : false;

      if (!action) savedProfiles = [];
      payload.profiles.forEach(p => {
        // Avoid duplicate names
        if (!savedProfiles.find(x => x.name === p.name)) savedProfiles.push(p);
      });

      // Restore dark cal if present and none currently captured
      if (!darkCaptured && payload.darkCaptured && payload.darkOffset) {
        darkOffset = payload.darkOffset;
        darkCaptured = true;
        calStatus.textContent = 'Dark offset loaded from file';
        calStatus.className = 'active';
        const mx = Math.max(...darkOffset, 1);
        darkOffset.forEach((v,i) => {
          const bar = document.getElementById('cb'+i);
          if (bar) bar.style.height = Math.max(2, Math.round(v/mx*36)) + 'px';
        });
      }

      renderSavedList();
      checkMatches(lastCorrected);
    } catch(err) {
      alert('Could not load file: ' + err.message);
    }
    e.target.value = ''; // reset so same file can be re-loaded
  };
  reader.readAsText(file);
});

// ── Spectral → hex colour ────────────────────────────────────────────────
function spectralToHex(vals) {
  let X=0,Y=0,Z=0;
  XYZ_W.forEach(([wx,wy,wz],i)=>{ X+=wx*vals[i]; Y+=wy*vals[i]; Z+=wz*vals[i]; });
  if(Y===0) return '#888888';
  X/=Y; Z/=Y; Y=1;
  let r= 3.2406*X-1.5372*Y-0.4986*Z;
  let g=-0.9689*X+1.8758*Y+0.0415*Z;
  let b= 0.0557*X-0.2040*Y+1.0570*Z;
  r=Math.max(0,r); g=Math.max(0,g); b=Math.max(0,b);
  const mx=Math.max(r,g,b,1e-9);
  r/=mx; g/=mx; b/=mx;
  const gm=v=>v<=0.0031308?12.92*v:1.055*Math.pow(v,1/2.4)-0.055;
  return '#'+[r,g,b].map(v=>Math.round(gm(v)*255).toString(16).padStart(2,'0')).join('');
}

// ── Status ───────────────────────────────────────────────────────────────
function setStatus(state, msg) {
  document.getElementById('statusDot').className='status-dot '+(state||'');
  document.getElementById('statusText').textContent=msg;
}

// ── Init ─────────────────────────────────────────────────────────────────
window.addEventListener('resize', ()=>drawSpectrum(lastCorrected));
drawSpectrum(new Array(10).fill(0));

if (!('serial' in navigator)) {
  setStatus('error','Web Serial not supported — use Chrome or Edge');
  btnConnect.disabled=true;
}
