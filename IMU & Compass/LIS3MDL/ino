#include <Wire.h>
#include <Adafruit_LIS3MDL.h>
#include <Adafruit_Sensor.h>
#include <EEPROM.h>
#include <WiFi.h>
#include <WebServer.h>
#include <math.h>

#define LIS3MDL_ADDR  0x1C
#define EEPROM_SIZE   24
#define CAL_ADDR      0

const char* ssid     = "ESP32 Access Point";
const char* password = "";

Adafruit_LIS3MDL lis3mdl;
WebServer server(80);

float offset_x = 0, offset_y = 0;
float min_x, max_x, min_y, max_y;
bool calibrating = false;
float currentBearing = 0;

// ── EEPROM ──────────────────────────────────────────────
void saveCalibration() {
  EEPROM.put(CAL_ADDR,      offset_x);
  EEPROM.put(CAL_ADDR + 4,  offset_y);
  EEPROM.commit();
  Serial.println("Calibration saved to EEPROM.");
}

void loadCalibration() {
  EEPROM.get(CAL_ADDR,     offset_x);
  EEPROM.get(CAL_ADDR + 4, offset_y);
  if (isnan(offset_x) || isnan(offset_y)) {
    offset_x = 0;
    offset_y = 0;
    Serial.println("No calibration found in EEPROM. Using defaults.");
  } else {
    Serial.print("Loaded calibration — offset_x: ");
    Serial.print(offset_x, 3);
    Serial.print("  offset_y: ");
    Serial.println(offset_y, 3);
  }
}

// ── WEB PAGES ────────────────────────────────────────────
String buildPage() {
  String page = "<!DOCTYPE html><html><head><meta charset='UTF-8'>";
  page += "<meta name='viewport' content='width=device-width,initial-scale=1'>";
  page += "<title>LIS3MDL Compass</title>";
  page += "<style>";
  page += "body{font-family:Helvetica,sans-serif;background:#f5f7fb;display:flex;justify-content:center;align-items:center;min-height:100vh;margin:0;}";
  page += ".card{background:#fff;border-radius:12px;padding:40px;box-shadow:0 2px 12px rgba(0,0,0,0.1);text-align:center;max-width:460px;width:90%;}";
  page += "h2{margin-top:0;font-size:22px;color:#1e293b;}";
  page += ".bearing-val{font-size:64px;font-weight:bold;color:#2563eb;margin:10px 0;}";
  page += ".bearing-label{font-size:20px;color:#64748b;margin-bottom:24px;}";
  page += ".compass{margin:20px auto;position:relative;width:200px;height:200px;}";
  page += ".compass svg{width:200px;height:200px;}";
  page += ".status{font-size:16px;font-weight:bold;margin:16px 0;color:#2563eb;}";
  page += "a{display:inline-block;margin:10px 6px;padding:14px 28px;border-radius:8px;font-size:16px;font-weight:bold;text-decoration:none;color:#fff;}";
  page += ".start{background:#2563eb;} .start:hover{background:#1e40af;}";
  page += ".stop{background:#dc2626;} .stop:hover{background:#b91c1c;}";
  page += "</style></head><body><div class='card'>";
  page += "<h2>LIS3MDL Compass</h2>";

  // Compass rose SVG
  page += "<div class='compass'><svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'>";
  page += "<circle cx='100' cy='100' r='95' fill='#f1f5f9' stroke='#cbd5e1' stroke-width='2'/>";
  page += "<text x='100' y='22' text-anchor='middle' font-size='16' font-weight='bold' fill='#dc2626'>N</text>";
  page += "<text x='100' y='188' text-anchor='middle' font-size='16' font-weight='bold' fill='#475569'>S</text>";
  page += "<text x='185' y='105' text-anchor='middle' font-size='16' font-weight='bold' fill='#475569'>E</text>";
  page += "<text x='15' y='105' text-anchor='middle' font-size='16' font-weight='bold' fill='#475569'>W</text>";
  // Needle — rotates via JS
  page += "<g id='needle' transform='rotate(0,100,100)'>";
  page += "<polygon points='100,20 94,100 100,115 106,100' fill='#dc2626'/>";
  page += "<polygon points='100,180 94,100 100,115 106,100' fill='#94a3b8'/>";
  page += "<circle cx='100' cy='100' r='6' fill='#1e293b'/>";
  page += "</g></svg></div>";

  page += "<div class='bearing-val' id='bearing'>---</div>";
  page += "<div class='bearing-label'>degrees</div>";
  page += "<div class='status' id='calstatus'>" + String(calibrating ? "Calibrating — rotate sensor 360°" : "Ready") + "</div>";

  if (!calibrating) {
    page += "<a class='start' href='/start'>Start Calibration</a>";
  } else {
    page += "<a class='stop' href='/stop'>Stop &amp; Save</a>";
  }

  page += "<script>";
  page += "function update(){";
  page += "fetch('/data').then(r=>r.json()).then(d=>{";
  page += "document.getElementById('bearing').textContent=d.bearing.toFixed(1);";
  page += "document.getElementById('needle').setAttribute('transform','rotate('+d.bearing+',100,100)');";
  page += "document.getElementById('calstatus').textContent=d.calibrating?'Calibrating — rotate sensor 360°':'Ready';";
  page += "});";
  page += "}";
  page += "setInterval(update,200);";
  page += "update();";
  page += "</script>";

  page += "</div></body></html>";
  return page;
}

void handleRoot() {
  server.send(200, "text/html", buildPage());
}

void handleData() {
  String json = "{\"bearing\":";
  json += String(currentBearing, 1);
  json += ",\"calibrating\":";
  json += calibrating ? "true" : "false";
  json += "}";
  server.send(200, "application/json", json);
}

void handleStart() {
  if (!calibrating) {
    calibrating = true;
    min_x = min_y =  1e9;
    max_x = max_y = -1e9;
    Serial.println("Calibration started.");
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleStop() {
  if (calibrating) {
    calibrating = false;
    offset_x = (max_x + min_x) / 2.0;
    offset_y = (max_y + min_y) / 2.0;
    saveCalibration();
    Serial.print("Calibration complete — offset_x: ");
    Serial.print(offset_x, 3);
    Serial.print("  offset_y: ");
    Serial.println(offset_y, 3);
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

// ── SETUP ────────────────────────────────────────────────
void setup() {
  Serial.begin(9600);
  EEPROM.begin(EEPROM_SIZE);
  Wire.begin();

  if (!lis3mdl.begin_I2C(LIS3MDL_ADDR)) {
    Serial.println("LIS3MDL not found. Check wiring.");
    while (1);
  }

  lis3mdl.setPerformanceMode(LIS3MDL_MEDIUMMODE);
  lis3mdl.setOperationMode(LIS3MDL_CONTINUOUSMODE);
  lis3mdl.setDataRate(LIS3MDL_DATARATE_10_HZ);
  lis3mdl.setRange(LIS3MDL_RANGE_4_GAUSS);

  loadCalibration();

  WiFi.softAP(ssid, password);
  Serial.print("AP started — connect to: ");
  Serial.println(ssid);
  Serial.print("Open: http://");
  Serial.println(WiFi.softAPIP());

  server.on("/",      handleRoot);
  server.on("/data",  handleData);
  server.on("/start", handleStart);
  server.on("/stop",  handleStop);
  server.begin();
}

// ── LOOP ─────────────────────────────────────────────────
void loop() {
  server.handleClient();

  sensors_event_t event;
  lis3mdl.getEvent(&event);

  float x = event.magnetic.x;
  float y = event.magnetic.y;

  if (calibrating) {
    if (x < min_x) min_x = x;
    if (x > max_x) max_x = x;
    if (y < min_y) min_y = y;
    if (y > max_y) max_y = y;
  }

  float cx = x - offset_x;
  float cy = y - offset_y;

  currentBearing = atan2(cy, cx) * 180.0 / PI;
  if (currentBearing < 0) currentBearing += 360.0;

  Serial.print("Bearing: ");
  Serial.print(currentBearing, 1);
  Serial.println(calibrating ? " deg  [CALIBRATING]" : " deg");

  delay(200);
}
